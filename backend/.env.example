# App
APP_NAME="Online Shop API"
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://shop:shop@localhost:5432/shopdb
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Payment (mock)
WEBHOOK_SECRET=mock_webhook_secret_change_me

# Email (SMTP)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@shop.com

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
